{
  "ConnectionStrings": {
    // LocalDB (recomendado para equipo):
    // - Cada integrante crea su propia base de datos local "BarberiaDB" en su PC.
    // - Todos comparten la MISMA estructura (tablas) gracias a las migraciones (EF Core).
    // - Los datos (registros) NO se comparten automáticamente; cada quien tendrá datos distintos
    //   hasta que se capturen/seedee información.
    // - No se necesita cambiar el Server por cada PC (es genérico).
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=BarberiaDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    }
}